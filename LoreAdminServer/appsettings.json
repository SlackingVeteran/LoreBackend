{
	"Logging": {
		"LogLevel": {
			"Default": "Information",
			"Microsoft.AspNetCore": "Warning",
			"Microsoft.Hosting.Lifetime": "Information"
		}
	},
	"Lore": {
		"PublicUrl": "http://localhost:9080",
		"Audiences": [ "localhost", "127.0.0.1"],
		"Oidc": {
			"Authority": "https://login.microsoftonline.com/REPLACE_TENANT_ID/v2.0",
			"ClientId": "REPLACE_CLIENT_ID",
			"ClientSecret": "REPLACE_CLIENT_SECRET",
			"CallbackPath": "/signin-oidc",
			"Scopes": [ "openid", "profile", "email" ],
			"UsernameClaim": "sub",
			"NameClaim": "name"
		},
		"Acl": {
			"Profiles": [
				{ "Id": "lore_reader", "Actions": [ "read" ] },
				{ "Id": "lore_writer", "Extends": [ "lore_reader" ], "Actions": [ "write" ] },
				{ "Id": "lore_admin", "Extends": [ "lore_writer" ], "Actions": [ "admin", "obliterate", "migrate" ] }
			],
			"Entries": [
				{ "Claim": { "Type": "roles", "Value": "Lore.Admin" }, "Profiles": [ "lore_admin" ], "Resources": [ "urc-*" ] },
				{ "Claim": { "Type": "roles", "Value": "Lore.ReadWrite" }, "Profiles": [ "lore_writer" ], "Resources": [ "urc-*" ] },
				{ "Claim": { "Type": "roles", "Value": "Lore.ReadOnly" }, "Profiles": [ "lore_reader" ], "Resources": [ "urc-*" ] }
			]
		}
	}
}
